# =============================================================================
# .gitignore — ea_copilot_workshop
# Audience: this repo is the BUILD SYSTEM that produces the EA Copilot workshop
# deliverables. We ignore build artifacts and generated outputs aggressively;
# we never ignore source-of-truth content (docs, prompts, instructions, etc.).
# =============================================================================

# ---- OS junk ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editors / IDE ----
.idea/
*.swp
*.swo
*~
.vs/

# Whitelist a curated set of .vscode files (committed for team consistency);
# everything else under .vscode/ is per-user and ignored.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/mcp.json
!.vscode/launch.json
!.vscode/tasks.json

# ---- Node tooling (extract-snippets, link-checker, prettier) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.pnpm-debug.log*

# ---- Python (helper scripts only) ----
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# ---- C++ / CMake / Ninja (snippet validation + demo workspace builds) ----
build/
out/
cmake-build-*/
CMakeUserPresets.json
CMakeCache.txt
CMakeFiles/
CTestTestfile.cmake
cmake_install.cmake
*.o
*.obj
*.exe
*.dll
*.so
*.so.*
*.dylib
*.a
*.lib
*.exp
compile_commands.json
.cache/

# ---- vcpkg ----
vcpkg_installed/
.vcpkg-root

# ---- Coverage / sanitizer artifacts ----
*.gcda
*.gcno
*.profraw
*.profdata
coverage/
lcov.info

# ---- Generated outputs (the EA-facing demo workspace lives here) ----
# We commit `output/ea-cpp-games/` (the demo C++ workspace; reproducible from prompts)
# and `output/.gitkeep`. Everything else under `output/` is local-only.
output/**
!output/.gitkeep
!output/README.md
!output/ea-cpp-games/
!output/ea-cpp-games/**

# Build artifacts inside the demo workspace are still ignored.
output/ea-cpp-games/build/
output/ea-cpp-games/build-*/
output/ea-cpp-games/vcpkg_installed/
output/ea-cpp-games/compile_commands.json
output/ea-cpp-games/.cache/
output/ea-cpp-games/.vscode/*
!output/ea-cpp-games/.vscode/settings.json
!output/ea-cpp-games/.vscode/extensions.json

# ---- Crash-dump local working copies ----
# Committed fixtures live under output/.../fixtures/crash_dumps/ (regenerated
# by prompts). Local working copies use the .local suffix and are ignored.
*.dmp.local
*.pdb.local

# ---- Secrets & env ----
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
secrets/

# ---- Logs ----
*.log
logs/

# ---- Vendored third-party builds (sources may be vendored or submoduled;
#      build outputs are always ignored) ----
third_party/**/build/
third_party/**/out/

# ---- Prompt run-state (memory/scratch the agent may produce locally) ----
.copilot/
.ai-state/
