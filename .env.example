# Copy this file to .env and fill in values. .env is gitignored.
# Used only by local tooling; CI uses GitHub Actions secrets instead.

# GitHub PAT (read-only, public repos) for the github MCP server.
# Scopes: public_repo, read:org. NEVER use a PAT with write/admin scopes here.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional: model preference override for prompt runs.
COPILOT_MODEL=
